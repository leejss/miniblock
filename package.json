{
	"name": "miniblock-monorepo",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev:core": "pnpm --filter @miniblock/core dev",
		"dev:react": "pnpm --filter @miniblock/react dev",
		"dev:demo": "pnpm --filter demo dev",
		"build:all": "pnpm --filter @miniblock/core build && pnpm --filter @miniblock/react build && pnpm --filter demo build",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"lint": "biome lint .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.12"
	},
	"workspaces": [
		"packages/*",
		"apps/*"
	]
}
