{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,

		// 모던 TypeScript 기능들 활성화
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,

		// 라이브러리 배포를 위해 선언(d.ts) 파일 생성 규칙 기본 장착
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	}
}
